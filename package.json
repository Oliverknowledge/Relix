{
  "name": "relix-growth-employee",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "anchor:build": "anchor build && anchor idl build -p relix_escrow -o app/lib/idl/relix_escrow.json -t app/lib/idl/relix_escrow.ts",
    "anchor:deploy:devnet": "anchor deploy --provider.cluster devnet",
    "anchor:test": "anchor test",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "coralos:build": "esbuild scripts/coralos/agent.ts --bundle --platform=node --format=esm --outfile=scripts/coralos/dist/agent.mjs",
    "coralos:server:build": "esbuild scripts/coralos/server.ts --bundle --platform=node --format=esm --outfile=scripts/coralos/dist/coralos-server.mjs",
    "coralos:server": "npm run coralos:build && npm run coralos:server:build && node scripts/coralos/dist/coralos-server.mjs",
    "coralos:verify": "npm run coralos:build && esbuild scripts/coralos/test-coralos-market.ts --bundle --platform=node --format=esm --outfile=scripts/coralos/dist/test-coralos-market.mjs && node scripts/coralos/dist/test-coralos-market.mjs",
    "coralos:docker:build": "docker build -f Dockerfile -t relix-coralos .",
    "coralos:docker:test": "bash scripts/coralos/docker-test.sh"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/web3.js": "^1.98.4",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "mocha": "^11.7.5",
    "tailwindcss": "^4.3.2",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.9.3"
  }
}
